{
  "generator": { "name": "dense", "column_span": 9999 },

  "lua_extension": "luau",

  "bundle": {
    "modules_identifier": "_MODULES",

    "require_mode": {
      "name": "path",
      "sources": {
        "@lib": "./lib"
      }
    }
  },

  "rules": [
    "remove_spaces",
    "remove_types",
    "remove_comments",
    "remove_nil_declaration",
    "compute_expression",
    "remove_unused_if_branch",
    "filter_after_early_return"
  ]
}
